<apex:page controller="SiteVisitQRController" action="{!checkAccess}"
           showHeader="false" sidebar="false" standardStylesheets="false"
           title="Site Visit">
    <apex:slds />
    <div class="slds-scope">
        <div class="slds-align_absolute-center" style="min-height: 70vh; flex-direction: column;">
            <div class="slds-box slds-theme_default slds-text-align_center slds-p-around_large" style="max-width: 32rem;">
                <span class="slds-icon_container slds-m-bottom_small" title="Prohibited">
                    <svg class="slds-icon slds-icon-text-error slds-icon_large" aria-hidden="true">
                        <use xlink:href="{!URLFOR($Asset.SLDS, 'assets/icons/utility-sprite/svg/symbols.svg#lock')}"></use>
                    </svg>
                </span>
                <h1 class="slds-text-heading_medium slds-text-color_error slds-p-top_small">
                    {!message}
                </h1>
                <p class="slds-text-body_regular slds-text-color_weak slds-p-top_x-small">
                    If you believe this is a mistake, please contact your administrator.
                </p>
            </div>
        </div>
    </div>
</apex:page>
